// Arduino code
const long BAUD = 115200;
const unsigned long sampleInterval = 10;

float k1 = 0.0253;
float k2 = 0.1454;
float k3 = -0.0569;
float k4 = 0.0415;

float gainScale = 50.0;
//int lastDir = 1;
unsigned long lastTime = 0;

// -------- PINS --------
const int armPinA = 20;
const int armPinB = 21;
const int pendPinA = 19;
const int pendPinB = 18;

// -------- MOTOR --------
const int motArmPWM = 5;
const int motArmDir = 4;
const float SUPPLY = 12.0;

// -------- ENCODERS --------
volatile long armCount = 0;
volatile long pendCount = 0;

// -------- FILTER --------
const float alpha = 0.75;

// -------- STATE --------
long armlastCount = 0;
long pendlastCount = 0;

float filarmVel = 0;
float filpendVel = 0;

float u = 0;

// OFFSET (adjust manually if needed)
float pend_offset = 0.0;

// -------- ENCODER SCALE --------
const int totalTicks = 2000;
const int halfTicks = 1000;
const float TICK_TO_RAD = PI / 1000.0;

// ======================================================
void setup() {
  Serial.begin(BAUD);

  pinMode(armPinA, INPUT_PULLUP);
  pinMode(armPinB, INPUT_PULLUP);
  pinMode(pendPinA, INPUT_PULLUP);
  pinMode(pendPinB, INPUT_PULLUP);

  attachInterrupt(digitalPinToInterrupt(armPinA), readArmA, CHANGE);
  attachInterrupt(digitalPinToInterrupt(armPinB), readArmB, CHANGE);
  attachInterrupt(digitalPinToInterrupt(pendPinA), readPendA, CHANGE);
  attachInterrupt(digitalPinToInterrupt(pendPinB), readPendB, CHANGE);

  pinMode(motArmPWM, OUTPUT);
  pinMode(motArmDir, OUTPUT);
  stopMotor();
  Serial.println("t,arm,pend,u");
}
// ======================================================
void loop() {

  unsigned long currentTime = millis();

  if (currentTime - lastTime >= sampleInterval) {

    float dt = (currentTime - lastTime) / 1000.0;

    long armCurrent, pendCurrent;

    noInterrupts();
    armCurrent = armCount;
    pendCurrent = pendCount;
    interrupts();

    // -------- DELTA --------
    float darm = armCurrent - armlastCount;
    float dpend = pendCurrent - pendlastCount;

    if (darm > halfTicks) darm -= totalTicks;
    else if (darm < -halfTicks) darm += totalTicks;

    if (dpend > halfTicks) dpend -= totalTicks;
    else if (dpend < -halfTicks) dpend += totalTicks;

    // -------- VELOCITY --------
    float armVel = (darm * TICK_TO_RAD) / dt;
    float pendVel = (dpend * TICK_TO_RAD) / dt;

    filarmVel = alpha * armVel + (1 - alpha) * filarmVel;
    filpendVel = alpha * pendVel + (1 - alpha) * filpendVel;

    // -------- ANGLES --------
    float arm = armCurrent * TICK_TO_RAD;
    float pend = pendCurrent * TICK_TO_RAD - pend_offset;

    // ==================================================
    //  LQR CONTROL
    // ==================================================
    float u_fb = -(k1*arm + k2*filarmVel + k3*pend + k4*filpendVel);

    //  BOOST POSITION RESPONSE
    u_fb = u_fb + 5.0 * pend;

    // SCALE
    u = gainScale * u_fb;

  
    // DIRECTION HOLD
  
    // if (abs(u) < 1.0) {
    //   u = lastDir * 1.0;
    // } else {
    //   lastDir = (u > 0) ? 1 : -1;
    // }

    applyVoltage(u);

    // -------- LOG --------
    Serial.print(currentTime); Serial.print(",");
    Serial.print(arm,4); Serial.print(",");
    Serial.print(pend,4); Serial.print(",");
    Serial.println(u,3);

    armlastCount = armCurrent;
    pendlastCount = pendCurrent;
    lastTime = currentTime;
  }
}


// MOTOR CONTROL

void applyVoltage(float volts) {

  // LIMIT
  if (volts > 6) volts = 6;
  if (volts < -6) volts = -6;

  float duty = volts / SUPPLY;

  if (duty > 1) duty = 1;
  if (duty < -1) duty = -1;

  int pwm = abs(duty) * 255;

  // MINIMUM PWM (OVERCOME FRICTION)
  if (pwm > 0 && pwm < 140) pwm = 140;

  digitalWrite(motArmDir, (duty > 0) ? LOW : HIGH);
  analogWrite(motArmPWM, pwm);
}

void stopMotor() {
  analogWrite(motArmPWM, 0);
}


// ENCODERS

void readArmA() {
  (digitalRead(armPinA) != digitalRead(armPinB)) ? armCount++ : armCount--;
}
void readArmB() {
  (digitalRead(armPinA) == digitalRead(armPinB)) ? armCount++ : armCount--;
}
void readPendA() {
  (digitalRead(pendPinA) != digitalRead(pendPinB)) ? pendCount++ : pendCount--;
}
void readPendB() {
  (digitalRead(pendPinA) == digitalRead(pendPinB)) ? pendCount++ : pendCount--;
}
